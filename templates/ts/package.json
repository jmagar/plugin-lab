{
  "name": "my-plugin-mcp",
  "version": "0.1.0",
  "description": "MCP server for My Plugin with dual transport (HTTP + stdio).",
  "type": "module",
  "main": "dist/my_plugin_mcp/index.js",
  "exports": {
    ".": {
      "types": "./dist/my_plugin_mcp/index.d.ts",
      "import": "./dist/my_plugin_mcp/index.js"
    }
  },
  "bin": {
    "my-plugin-mcp": "./dist/my_plugin_mcp/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/my_plugin_mcp/index.js",
    "dev": "tsx watch my_plugin_mcp/index.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('.cache/vitest',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "fmt": "biome format --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:ci": "biome ci ."
  },
  "keywords": [
    "mcp",
    "homelab",
    "typescript",
    "express",
    "zod"
  ],
  "author": "Your team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/my-plugin-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/my-plugin-mcp/issues"
  },
  "homepage": "https://github.com/your-org/my-plugin-mcp#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
