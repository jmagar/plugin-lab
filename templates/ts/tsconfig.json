{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "tsBuildInfoFile": ".cache/tsconfig.tsbuildinfo"
  },
  "include": [
    "my_plugin_mcp/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    ".cache"
  ]
}
